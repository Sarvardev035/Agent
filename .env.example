# Exchange Rate API
# Get free key at https://www.exchangerate-api.com
VITE_EXCHANGE_API_KEY=your_api_key_here

# Backend API
VITE_API_URL=https://finly.uyqidir.uz
# Optional override (preferred if both are set)
VITE_API_BASE_URL=https://finly.uyqidir.uz

# Auth transport mode:
# false = Bearer token in Authorization header (default)
# true  = cross-site cookies/credentials mode (requires backend CORS credentials support)
VITE_USE_API_CREDENTIALS=false

# AI Assistant (Groq/OpenAI-compatible)
# IMPORTANT: keep this only in .env.local, never commit real secrets
VITE_AI_API_KEY=your_ai_api_key_here
# Optional (default is Groq OpenAI-compatible endpoint)
VITE_AI_API_BASE_URL=https://api.groq.com/openai/v1
# Optional model override
VITE_AI_MODEL=llama-3.1-8b-instant
